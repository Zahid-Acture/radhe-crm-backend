# ─── Radhe CRM — Backend Environment Variables ───────────────
# Copy this file to .env and fill in your values

# MySQL Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ActureMedia
DB_NAME=radhe_crm

# JWT Secret (generate a long random string)
JWT_SECRET=radhe2024secretkey
JWT_EXPIRES_IN=8h

# Server
PORT=4000
NODE_ENV=development

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173
